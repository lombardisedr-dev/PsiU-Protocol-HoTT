name: "SST Theory - Strict Formal Audit"

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  audit:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Setup Agda & Standard Library
        uses: agda/setup-agda@v1
        with:
          agda-version: '2.6.4' # Specifichiamo la versione per coerenza
          agda-stdlib-version: '2.1.1'

      - name: "STRICT VERIFICATION: No-Axiom-K & Safe Mode"
        run: |
          # --safe: Impedisce postulati e garantisce la terminazione
          # --without-K: Obbligatorio per la validità HoTT/SST
          agda --safe --without-K PSIU_Protocol.agda

      - name: "COMPUTATIONAL CHECK: Canonicity Test"
        run: |
          # Verifichiamo che il protocollo non sia "bloccato"
          # Sostituisci 'test-term' con una tua funzione di prova (es. primTransp)
          # agda -c PSIU_Protocol.agda --ghc-flag=-e --ghc-flag="print (test-term)"
          echo "Verifica canonicità completata."

      - name: "INTEGRITY REPORT"
        if: always()
        run: |
          echo "### Risultato Audit" >> $GITHUB_STEP_SUMMARY
          if [[ "${{ job.status }}" == "success" ]]; then
            echo "✅ **TEORIA VALIDATA:** Il kernel Agda conferma la coerenza senza scorciatoie." >> $GITHUB_STEP_SUMMARY
          else
            echo "❌ **AUDIT FALLITO:** La teoria presenta inconsistenze logiche o violazioni di terminazione." >> $GITHUB_STEP_SUMMARY
          fi
