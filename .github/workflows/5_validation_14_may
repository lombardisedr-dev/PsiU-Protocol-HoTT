name: "SST Formal Verification - PSIU Protocol"

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  formal-verification:
    runs-on: ubuntu-latest
    container: 
      image: agda/agda:latest # Usa un ambiente controllato

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Verify "No Axiom K" Compliance
        run: |
          # Questo comando forza Agda a fallire se rileva l'Assioma K
          agda --safe --without-K Psi_Protocol_implementation_2.agda

      - name: Stress Test - Lambda Filter (Filtro-λ)
        run: |
          # Verifichiamo la riduzione in forma normale (Canonicità)
          agda -c --ghc-flag=-O2 Psi_Protocol_implementation_2.agda
          # Se il compilatore GHC non riesce a ottimizzare o trova termini bloccati, fallisce qui.

      - name: Generate Formal Proof Report
        if: success()
        run: |
          echo "### ✅ SST Theory Verified" >> $GITHUB_STEP_SUMMARY
          echo "The PSIU Protocol has passed the ABS-HONESTY stress test." >> $GITHUB_STEP_SUMMARY
          echo "Status: 1/3 Gnomonic Symmetry validated via Agda Cubical Kernel." >> $GITHUB_STEP_SUMMARY
